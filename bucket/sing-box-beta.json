{
    "version": "1.14.0-alpha.2",
    "description": "The universal proxy platform (beta version).",
    "homepage": "https://sing-box.sagernet.org/",
    "license": "GPL-3.0-or-later",
    "notes": [
        "If you want to use TUN mode, please run sing-box with administrator privileges.",
        "Your configuration and cache files are persisted in '$persist_dir'.",
        "You can run with a directory of configs using: 'sing-box run -C $persist_dir\\config.d'"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.14.0-alpha.2/sing-box-1.14.0-alpha.2-windows-amd64.zip",
            "hash": "e4a39ae9e0b0f5166558849a607a2780f0f43ab4424c305bcf191674dba001d7",
            "extract_dir": "sing-box-1.14.0-alpha.2-windows-amd64"
        },
        "32bit": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.14.0-alpha.2/sing-box-1.14.0-alpha.2-windows-386.zip",
            "hash": "3edc18b64ecb006f47ebf245c442aa57f9c8e92c071f1d5cf7c614a690432ec8",
            "extract_dir": "sing-box-1.14.0-alpha.2-windows-386"
        },
        "arm64": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.14.0-alpha.2/sing-box-1.14.0-alpha.2-windows-arm64.zip",
            "hash": "1661eec5f05a5ff47b442a9702f9b44d0fb1ad4ca71c75a9c72a9fcbcaceb6b7",
            "extract_dir": "sing-box-1.14.0-alpha.2-windows-arm64"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) { New-Item -Path \"$persist_dir\" -ItemType Directory | Out-Null }",
        "if (!(Test-Path \"$persist_dir\\config.json\")) {",
        "   $utf8NoBom = New-Object System.Text.UTF8Encoding($false)",
        "   [System.IO.File]::WriteAllText(\"$persist_dir\\config.json\", \"{}`n\", $utf8NoBom)",
        "}",
        "if (!(Test-Path \"$persist_dir\\cache.db\")) { New-Item -Path \"$persist_dir\\cache.db\" -ItemType File | Out-Null }"
    ],
    "bin": "sing-box.exe",
    "persist": [
        "config",
        "config.d",
        "config.json",
        "cache.db",
        "ui"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/SagerNet/sing-box/releases",
        "jsonpath": "$.[?(@.prerelease==true)].tag_name",
        "regex": "v([-\\d.\\w]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/SagerNet/sing-box/releases/download/v$version/sing-box-$version-windows-amd64.zip",
                "extract_dir": "sing-box-$version-windows-amd64"
            },
            "32bit": {
                "url": "https://github.com/SagerNet/sing-box/releases/download/v$version/sing-box-$version-windows-386.zip",
                "extract_dir": "sing-box-$version-windows-386"
            },
            "arm64": {
                "url": "https://github.com/SagerNet/sing-box/releases/download/v$version/sing-box-$version-windows-arm64.zip",
                "extract_dir": "sing-box-$version-windows-arm64"
            }
        }
    }
}
