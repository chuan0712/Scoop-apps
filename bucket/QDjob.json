            "hash": "48e7f1fe24384c8deaf324925c0b7764a09a60ce96187149a73d74bb4822aa5e"
        }
    },
    "pre_install": [
        "Set-Content -Path \"$dir\\qd.ps1\" -Value \"Set-Location $dir; .\\QDjob.exe $args\""
