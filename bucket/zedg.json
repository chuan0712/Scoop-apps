    "architecture": {
        "64bit": {
            "url": "https://github.com/x6nux/zed-globalization/releases/download/v1.0.0/zedg-zh-cn-windows-x86_64-v1.0.0.zip",
            "hash": "d95b3a51fd614c076c8866f0497c0f2c6b747180e74b85af0fd4b60fde55265c"
        },
        "arm64": {
            "url": "https://github.com/x6nux/zed-globalization/releases/download/v1.0.0/zedg-zh-cn-windows-aarch64-v1.0.0.zip",
            "hash": "fa54271ef379fca3cd5847640d3c2874fc7dfefa8ae228260cee35aeed32262b"
        }
    },
    "post_install": [
        "# 处理 AppData\\Roaming\\Zed (配置和用户数据)",
        "if (Test-Path $env:APPDATA\\Zed) {",
        "    Copy-Item -Path $env:APPDATA\\Zed\\* -Destination \"$persist_dir\\roaming\" -Force -Recurse",
        "    Remove-Item $env:APPDATA\\Zed -Force -Recurse",
        "}",
        "New-Item -ItemType Junction -Path $env:APPDATA\\Zed -Target \"$persist_dir\\roaming\" | Out-Null",
        "",
        "# 处理 AppData\\Local\\Zed (缓存和临时数据)",
        "if (Test-Path $env:LOCALAPPDATA\\Zed) {",
        "    Copy-Item -Path $env:LOCALAPPDATA\\Zed\\* -Destination \"$persist_dir\\local\" -Force -Recurse",
        "    Remove-Item $env:LOCALAPPDATA\\Zed -Force -Recurse",
        "}",
        "New-Item -ItemType Junction -Path $env:LOCALAPPDATA\\Zed -Target \"$persist_dir\\local\" | Out-Null"
    ],
    "uninstaller": {
        "script": [
            "Remove-Item $env:APPDATA\\Zed -Force -Recurse -ErrorAction SilentlyContinue",
            "Remove-Item $env:LOCALAPPDATA\\Zed -Force -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "persist": [
        "roaming",
        "local"
    ],
    "bin": "ZedG.exe",
    "shortcuts": [
        [
            "ZedG.exe",
            "ZedG"
        ]
    ],
    "checkver": {
        "github": "https://github.com/x6nux/zed-globalization"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/zedg-zh-cn-windows-x86_64-v$version.zip"
            },
            "arm64": {
                "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/zedg-zh-cn-windows-aarch64-v$version.zip"
            }
        }
    }
}
